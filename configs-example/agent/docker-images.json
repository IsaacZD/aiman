[
  {
    "id": "vllm-openai",
    "name": "vLLM OpenAI",
    "image": "vllm/vllm-openai:latest",
    "ports": ["8000:8000"],
    "volumes": ["/models:/models:ro"],
    "env": [{ "key": "HF_HOME", "value": "/data/hf" }],
    "run_args": [],
    "gpus": "all",
    "user": null,
    "command": "python -m vllm.entrypoints.openai.api_server",
    "args": ["--model", "/models/llama"],
    "pull": true,
    "remove": true,
    "build": {
      "dockerfile_content": "FROM vllm/vllm-openai:latest",
      "build_args": [{ "key": "VLLM_VERSION", "value": "latest" }],
      "pull": true,
      "no_cache": false
    }
  }
]
